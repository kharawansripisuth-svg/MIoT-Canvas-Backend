# Telegraf Configuration for Unknown Customer
[agent]
interval = "10s"
round_interval = true
metric_batch_size = 1000
metric_buffer_limit = 10000
flush_interval = "10s"
flush_jitter = "0s"

[[outputs.influxdb]]
urls = ["http://localhost:8086"]
database = "C0001"
skip_database_creation = false
timeout = "5s"

# TOPIC_ID: 00000001
[[inputs.mqtt_consumer]]
servers = ["tcp://undefined:undefined"]
topics = ["undefined"]
qos = 0
connection_timeout = "30s"
data_format = "json"
tag_keys = ["Temp Sensor 01"]
name_override = "Temp Sensor 01"